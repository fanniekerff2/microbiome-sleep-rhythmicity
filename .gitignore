# exclude Python cache files
**/scripts/__pycache__/
*.pyc

# ignore .order files
*.order

# exclude out files (.out)
**/scripts/qiime2/out/*.out

# exclude processed data files (.qza and .qzv)
*.qza
*.qzv

# exclude large pdf files
**/figures/*.pdf

# exclude analyses not included in the manuscript
**/z_archive/**